// uniple checkout — Shopify app Prisma schema
// codex 査読 r70 反映: GID 正規化 / idempotency / amount-currency / status string enum

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

// Shopify CLI scaffold default = OAuth session
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// uniple 加盟店設定 (= shop ごと、 secret は app-level encryption key で暗号化推奨)
model ShopSettings {
  id                    String    @id @default(cuid())
  shop                  String    @unique
  apiBaseUrl            String    @default("https://uniple.io")
  apiKey                String // 暗号化 at rest 推奨 (= sodium secretbox 等)
  webhookSecret         String // 同上
  merchantLabel         String
  mode                  String    @default("live") // live | test
  x402LastSyncSynced    Int?
  x402LastSyncActive    Int?
  x402LastSyncInactive  Int?
  x402LastSyncSkipped   Int?
  x402LastSyncError     String?
  x402LastSyncAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// Shopify order ↔ uniple session mapping
model OrderMapping {
  id                    String   @id @default(cuid())
  shop                  String
  // Shopify Order GID 正規化形式 (= gid://shopify/Order/<numeric>)
  shopifyOrderId        String
  // numeric も保持 (= webhook payload 互換)
  shopifyOrderNumericId String
  unipleSessionId       String   @unique
  unipleEnv             String   @default("live")
  amountJpyc            Int
  currency              String   @default("JPY")
  // pending | paid | paid_pending | failed | expired | cancelled
  status                String   @default("pending")
  txHash                String?
  payer                 String?
  lastError             String?
  retryCount            Int      @default(0)
  // idempotency: 処理済 webhook eventId 履歴 (= JSON string array)
  processedEventIds     String   @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([shop, shopifyOrderId])
  @@index([shop])
  @@index([status])
}

// x402 productSku ↔ Shopify variant mapping. Synced from Shopify product variants.
model X402Product {
  id               String   @id @default(cuid())
  shop             String
  externalId       String   @unique
  shopifyProductId String
  shopifyVariantId String
  name             String
  priceJpyc        String
  aiEnabled        Boolean  @default(true)
  active           Boolean  @default(true)
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
}

// x402 webhook idempotency + created Shopify order record.
model X402Order {
  id                String   @id @default(cuid())
  shop              String
  idempotencyKey    String   @unique
  productSku        String
  shopifyOrderId    String?
  shopifyOrderName  String?
  amountJpyc        String
  txHash            String?
  payer             String?
  status            String   @default("processing") // processing | created | failed
  lastError         String?
  processedEventIds String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shop])
  @@index([status])
}

// x402 shipping quote reservation for Shopify product variant purchases.
model X402Quote {
  id                  String    @id @default(cuid())
  quoteId             String    @unique
  shop                String
  productSku          String
  shopifyProductId    String
  shopifyVariantId    String
  quantity            Int
  productSubtotalJpyc String
  shippingFeeJpyc     String
  discountJpyc        String    @default("0")
  totalJpyc           String
  shippingJson        String
  shippingRateId      String?
  shippingRateLabel   String?
  quoteSource         String    @default("shopify")
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shop])
  @@index([productSku])
  @@index([expiresAt])
}
